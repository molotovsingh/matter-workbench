# Matter Workbench local configuration.
# Copy to .env and fill only the providers you intentionally use.

# Optional server settings.
PORT=4173
MATTERS_HOME=
MATTER_ROOT=

# OpenAI direct is the default provider for the skill router and
# /create_listofdates unless SOURCE_BACKED_ANALYSIS_PROVIDER=openrouter.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MAX_OUTPUT_TOKENS=3000
OPENAI_ROUTER_MAX_OUTPUT_TOKENS=1200

# /create_listofdates provider selection.
# Leave as openai-direct for the default OpenAI Responses API path.
# Set to openrouter only when you want chronology generation through OpenRouter.
SOURCE_BACKED_ANALYSIS_PROVIDER=openai-direct
OPENROUTER_API_KEY=
OPENROUTER_SOURCE_BACKED_ANALYSIS_MODEL=
OPENROUTER_SOURCE_BACKED_ANALYSIS_MAX_OUTPUT_TOKENS=3000
OPENROUTER_SOURCE_BACKED_ANALYSIS_TIMEOUT_MS=90000

# /describe_sources uses OpenRouter and writes Source Index.json labels.
OPENROUTER_SOURCE_DESCRIPTION_MODEL=
OPENROUTER_SOURCE_DESCRIPTION_MAX_OUTPUT_TOKENS=3000
OPENROUTER_SOURCE_DESCRIPTION_TIMEOUT_MS=90000
OPENROUTER_SOURCE_DESCRIPTION_PROVIDER_ORDER=
OPENROUTER_SOURCE_DESCRIPTION_PROVIDER_SORT=
OPENROUTER_SOURCE_DESCRIPTION_MAX_PROMPT_PRICE=
OPENROUTER_SOURCE_DESCRIPTION_MAX_COMPLETION_PRICE=

# OCR is opt-in. Mistral is only used when the explicit gate is enabled.
MISTRAL_API_KEY=
MISTRAL_OCR_ENABLED=0
